# Skopírujte tento súbor ako ".env" (bez .example) a vyplňte skutočné hodnoty
# zo Supabase (Project Settings → API / Data API).
#
# VITE_SUPABASE_ANON_KEY je bezpečné mať aj vo verejnom repozitári / vo
# vyexportovanej appke — nikdy sem ale nedávajte "service_role" kľúč.

VITE_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
